SUPABASE_URL=
SUPABASE_KEY=
# Service role key (Settings > API). Usada para operações administrativas
# (criar org/membros). Se vazia, usa SUPABASE_KEY.
SUPABASE_SERVICE_KEY=

OPENAI_API_KEY=

OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
ENVIRONMENT=development

# Fallback/seed. Com multiusuário o org_id vem do usuário autenticado.
DEFAULT_ORGANIZATION_ID=

USE_MOCK_AI=true
